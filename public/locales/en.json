  "terms": {
    "title": "Terms and Conditions",
    "intro": "By using",
    "introCont": "website, you agree to the following terms and conditions. Please read them carefully before completing any purchase.",
    "definitions": {
      "title": "Definitions",
      "store": "Our Store / We / Company",
      "storeDesc": "Refers to Our Store e-commerce platform for product delivery.",
      "customer": "Customer / User / You",
      "customerDesc": "Refers to any person using the website, application, or making a purchase.",
      "service": "Service",
      "serviceDesc": "Includes selling and delivering products through the website and mobile application."
    },
    "eligibility": {
      "title": "Eligibility",
      "desc": "Users must be 18 years or older to create an account and make purchases. By completing a purchase, the user confirms they are legally eligible to contract."
    },
    "products": {
      "title": "Products and Prices",
      "desc": "All displayed products are subject to availability. We strive to display accurate images and correct descriptions. Prices are shown in Saudi Riyals (SAR) and include all applicable taxes. We reserve the right to modify prices at any time without prior notice, but confirmed prices at the time of order will not change."
    },
    "order": {
      "title": "Order and Payment",
      "desc": "Minimum order is 3,000 SAR. Payments are accepted via Hesabi payment gateway which includes Visa, Mastercard, and Apple Pay.",
      "desc2": "Order confirmation constitutes a binding contract between both parties. We reserve the right to refuse or cancel any order in case of product unavailability, price errors, or incorrect order information."
    },
    "delivery": {
      "title": "Delivery",
      "desc": "We deliver to all regions of Saudi Arabia from 10:00 AM to 10:00 PM. Delivery times mentioned are estimates and may be affected by weather conditions, traffic, or other circumstances beyond our control.",
      "desc2": "The customer is responsible for providing a correct delivery address and active phone number. If delivery fails due to incorrect information from the customer, the customer may bear additional delivery fees."
    },
    "returns": {
      "title": "Returns and Exchanges",
      "desc": "Returns and exchanges are subject to our return and exchange policy published on our website. Return or exchange requests must be submitted within 24 hours of receiving the order."
    },
    "account": {
      "title": "User Account",
      "desc": "The user is responsible for maintaining the confidentiality of their account information and password. Any activity through your account is your responsibility. You must notify us immediately of any unauthorized use of your account."
    },
    "intellectual": {
      "title": "Intellectual Property",
      "desc": "All content displayed on the website and application including logos, designs, texts, and images are the exclusive property of",
      "desc2": "and are protected by intellectual property laws. Copying or using any content without prior written permission is prohibited."
    },
    "liability": {
      "title": "Limitation of Liability",
      "desc": "We are not liable for any indirect damages resulting from the use of our services. Our maximum liability does not exceed the value of the relevant order."
    },
    "governing": {
      "title": "Governing Law",
      "desc": "These terms and conditions are governed by the laws of Saudi Arabia. Any dispute arising from the use of our services is subject to the jurisdiction of the courts of Saudi Arabia."
    },
    "amendments": {
      "title": "Amendments",
      "desc": "We reserve the right to amend these terms and conditions at any time. Amendments become effective immediately upon posting on the website. Your continued use of our services after amendments constitutes acceptance of the updated terms."
    }
  },
  "privacy": {
    "title": "Privacy Policy",
    "intro": "We at",
    "introCont": "value our customers' privacy and are committed to protecting their personal data. This policy explains how we collect, use, and protect the information we obtain through our website and mobile application.",
    "collect": {
      "title": "Data We Collect",
      "personal": "Personal Information",
      "personalDesc": "We collect the following information when registering or placing an order: full name, phone number, delivery address, email (optional), and previous order details.",
      "technical": "Technical Data",
      "technicalDesc": "We also automatically collect technical data such as: device and browser type, IP address, and usage and browsing data to improve user experience."
    },
    "use": {
      "title": "How We Use Your Data",
      "desc": "We use your data for the following purposes:",
      "processOrders": "Process and deliver your orders",
      "communicate": "Communicate with you regarding your orders and account",
      "offers": "Send offers and updates (you can unsubscribe at any time)",
      "improve": "Improve our products and services"
    },
    "protection": {
      "title": "Data Protection",
      "desc": "We take appropriate security measures to protect your personal data from unauthorized access, modification, disclosure, or destruction. All payments are processed through the secure Hesabi payment gateway and we do not store bank card data on our servers."
    },
    "sharing": {
      "title": "Data Sharing with Third Parties",
      "desc": "We do not sell or rent your personal data to any third party. We may share some data with service providers who help us operate our business, such as delivery companies and payment gateways, only to the extent necessary to provide the service."
    },
    "cookies": {
      "title": "Cookies",
      "desc": "We use cookies to improve browsing experience and remember your preferences. You can disable cookies from your browser settings, but this may affect some website functions."
    },
    "rights": {
      "title": "Your Rights",
      "desc": "You have the right at any time to:",
      "access": "Request access to your personal data stored with us",
      "correct": "Request correction or update of your data",
      "delete": "Request deletion of your account and personal data",
      "unsubscribe": "Unsubscribe from marketing messages",
      "contact": "To exercise any of these rights, please contact us via WhatsApp."
    },
    "amendments": {
      "title": "Privacy Policy Amendments",
      "desc": "We reserve the right to amend this policy at any time. Any changes will be posted on this page with an updated last modified date. We recommend reviewing this policy periodically."
    }
  },
